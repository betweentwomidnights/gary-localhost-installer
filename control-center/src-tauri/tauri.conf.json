{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "gary4local",
  "version": "0.1.4",
  "identifier": "com.betweentwomidnights.gary4local",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "bash src-tauri/scripts/stage_runtime_resources.sh && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "gary4local",
        "width": 1100,
        "height": 700,
        "minWidth": 900,
        "minHeight": 550,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/nsis-hooks.nsh",
        "installerIcon": "./icons/icon.ico",
        "headerImage": "./windows/installer-header.bmp",
        "sidebarImage": "./windows/installer-sidebar.bmp",
        "languages": ["English"],
        "customLanguageFiles": {
          "English": "./windows/installer-english.nsh"
        }
      }
    },
    "resources": [
      "resources/services/**/*",
      "resources/icon.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
