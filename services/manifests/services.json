{
  "version": "2.0",
  "services": [
    {
      "id": "gary",
      "displayName": "gary (musicgen)",
      "description": "MusicGen continuation and generation service",
      "port": 8000,
      "entryPoint": "g4l_localhost.py",
      "workingDir": "services/gary",
      "pythonVersion": "3.11",
      "torchVersion": "2.7.1",
      "torchIndex": "https://download.pytorch.org/whl/cu128",
      "torchPackages": ["torch==2.7.1", "torchaudio==2.7.1"],
      "requirementsFile": "requirements.txt",
      "editableInstall": true,
      "editablePackagePath": ".",
      "editableInstallFlags": "--no-deps",
      "xformersShim": true,
      "forceTorchReinstall": true,
      "buildSteps": [
        "pip install torch==2.7.1 torchaudio==2.7.1 --index-url https://download.pytorch.org/whl/cu128",
        "pip install -e . --no-deps",
        "pip install -r requirements.txt",
        "pip install https://github.com/sdbds/flash-attention-for-windows/releases/download/2.8.2/flash_attn-2.8.2+cu128torch2.7.1cxx11abiFALSEfullbackward-cp311-cp311-win_amd64.whl",
        "install_xformers_shim",
        "pip install --force-reinstall --no-deps torch==2.7.1 torchaudio==2.7.1 --index-url https://download.pytorch.org/whl/cu128",
        "pip uninstall torchvision"
      ],
      "healthCheck": {
        "endpoint": "/health",
        "intervalSeconds": 15,
        "timeoutSeconds": 5,
        "startupGraceSeconds": 60
      },
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONLEGACYWINDOWSSTDIO": "1"
      },
      "dependsOn": []
    },
    {
      "id": "melodyflow",
      "displayName": "terry (melodyflow)",
      "description": "Audio editing and continuation with MelodyFlow",
      "port": 8002,
      "entryPoint": "localhost_melodyflow.py",
      "workingDir": "services/melodyflow",
      "pythonVersion": "3.11",
      "torchVersion": "2.7.1",
      "torchIndex": "https://download.pytorch.org/whl/cu128",
      "torchPackages": ["torch==2.7.1", "torchaudio==2.7.1", "torchvision==0.22.1"],
      "requirementsFile": "requirements.txt",
      "xformersShim": true,
      "forceTorchReinstall": true,
      "buildSteps": [
        "pip install torch==2.7.1 torchaudio==2.7.1 torchvision==0.22.1 --index-url https://download.pytorch.org/whl/cu128",
        "pip install -r requirements.txt",
        "pip install https://github.com/sdbds/flash-attention-for-windows/releases/download/2.8.2/flash_attn-2.8.2+cu128torch2.7.1cxx11abiFALSEfullbackward-cp311-cp311-win_amd64.whl",
        "install_xformers_shim",
        "pip install --force-reinstall --no-deps torch==2.7.1 torchaudio==2.7.1 torchvision==0.22.1 --index-url https://download.pytorch.org/whl/cu128"
      ],
      "healthCheck": {
        "endpoint": "/health",
        "intervalSeconds": 15,
        "timeoutSeconds": 5,
        "startupGraceSeconds": 90
      },
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONLEGACYWINDOWSSTDIO": "1"
      },
      "dependsOn": []
    },
    {
      "id": "stable-audio",
      "displayName": "jerry (stable audio)",
      "description": "Text-to-audio synthesis with Stable Audio Open Small",
      "port": 8005,
      "entryPoint": "api.py",
      "workingDir": "services/stable-audio",
      "pythonVersion": "3.11",
      "torchVersion": "2.7.1",
      "torchIndex": "https://download.pytorch.org/whl/cu128",
      "torchPackages": ["torch==2.7.1", "torchaudio==2.7.1", "torchvision==0.22.1"],
      "requirementsFile": "requirements.txt",
      "editableInstall": true,
      "editablePackagePath": ".",
      "editableInstallFlags": "--no-deps",
      "forceTorchReinstall": true,
      "buildSteps": [
        "pip install torch==2.7.1 torchaudio==2.7.1 torchvision==0.22.1 --index-url https://download.pytorch.org/whl/cu128",
        "pip install -e . --no-deps",
        "pip install -r requirements.txt",
        "pip install https://github.com/sdbds/flash-attention-for-windows/releases/download/2.8.2/flash_attn-2.8.2+cu128torch2.7.1cxx11abiFALSEfullbackward-cp311-cp311-win_amd64.whl",
        "pip install --force-reinstall --no-deps torch==2.7.1 torchaudio==2.7.1 --index-url https://download.pytorch.org/whl/cu128"
      ],
      "healthCheck": {
        "endpoint": "/health",
        "intervalSeconds": 15,
        "timeoutSeconds": 5,
        "startupGraceSeconds": 120
      },
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "HF_TOKEN": "${HF_TOKEN}"
      },
      "dependsOn": []
    },
    {
      "id": "carey",
      "displayName": "carey (ace-step 1.5)",
      "description": "Stem generation (lego), continuation (complete), and remix (cover) with ACE-Step",
      "port": 8003,
      "entryPoint": "carey_wrapper.py",
      "workingDir": "services/carey",
      "pythonVersion": "3.11",
      "torchVersion": "2.7.1",
      "torchIndex": "https://download.pytorch.org/whl/cu128",
      "torchPackages": ["torch==2.7.1", "torchvision==0.22.1", "torchaudio==2.7.1"],
      "requirementsFile": "requirements.txt",
      "extraInstalls": [
        {"command": "pip install -e acestep/third_parts/nano-vllm", "description": "Bundled nano-vllm with triton-windows + flash-attn"}
      ],
      "forceTorchReinstall": true,
      "buildSteps": [
        "pip install torch==2.7.1 torchvision==0.22.1 torchaudio==2.7.1 --index-url https://download.pytorch.org/whl/cu128",
        "pip install -e . --no-deps",
        "pip install -r requirements.txt",
        "pip install -e acestep/third_parts/nano-vllm",
        "pip install --force-reinstall --no-deps torch==2.7.1 torchaudio==2.7.1 --index-url https://download.pytorch.org/whl/cu128"
      ],
      "healthCheck": {
        "endpoint": "/health",
        "intervalSeconds": 15,
        "timeoutSeconds": 5,
        "startupGraceSeconds": 120
      },
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "ACESTEP_INIT_LLM": "false",
        "ACESTEP_CONFIG_PATH": "acestep-v15-base",
        "ACESTEP_NO_INIT": "true"
      },
      "dependsOn": []
    },
    {
      "id": "foundation",
      "displayName": "foundation-1",
      "description": "RoyalCities Foundation-1 text-to-sample generation with RC-stable-audio-tools",
      "port": 8015,
      "entryPoint": "api_foundation.py",
      "workingDir": "services/foundation",
      "pythonVersion": "3.11",
      "torchVersion": "2.7.1",
      "torchIndex": "https://download.pytorch.org/whl/cu128",
      "torchPackages": ["torch==2.7.1", "torchaudio==2.7.1", "torchvision==0.22.1"],
      "requirementsFile": "requirements.txt",
      "editableInstall": true,
      "editablePackagePath": "./RC-stable-audio-tools",
      "editableInstallFlags": "--no-deps",
      "forceTorchReinstall": true,
      "buildSteps": [
        "pip install torch==2.7.1 torchaudio==2.7.1 torchvision==0.22.1 --index-url https://download.pytorch.org/whl/cu128",
        "pip install setuptools",
        "pip install -e ./RC-stable-audio-tools --no-deps",
        "pip install -r requirements.txt",
        "pip install https://github.com/sdbds/flash-attention-for-windows/releases/download/2.8.2/flash_attn-2.8.2+cu128torch2.7.1cxx11abiFALSEfullbackward-cp311-cp311-win_amd64.whl",
        "pip install --force-reinstall --no-deps torch==2.7.1 torchaudio==2.7.1 --index-url https://download.pytorch.org/whl/cu128"
      ],
      "healthCheck": {
        "endpoint": "/health",
        "intervalSeconds": 15,
        "timeoutSeconds": 5,
        "startupGraceSeconds": 180
      },
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "HF_TOKEN": "${HF_TOKEN}",
        "FOUNDATION_MODEL_DIR": "${MODELS_DIR}/foundation-1",
        "FOUNDATION_CKPT_PATH": "${MODELS_DIR}/foundation-1/Foundation_1.safetensors",
        "FOUNDATION_CONFIG_PATH": "${MODELS_DIR}/foundation-1/model_config.json"
      },
      "dependsOn": []
    }
  ],
  "infrastructure": {},
  "defaults": {
    "pythonVersion": "3.11",
    "modelsDir": "${APPDATA}/Gary4JUCE/models",
    "logsDir": "${APPDATA}/Gary4JUCE/logs",
    "servicesDir": "${APPDATA}/Gary4JUCE/services"
  }
}
