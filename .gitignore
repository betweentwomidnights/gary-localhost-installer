# Python / bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual envs
.venv/
venv/
installer_env/

# Environment files (ignore real secrets, keep the template)
.env
.env.*
..env.un~
!.env.example


# Build artifacts
build/
dist/
output/
*.egg-info/

# PyInstaller temp (keep .spec for transparency)
# *.spec  <-- intentionally NOT ignored

# Redis binaries downloaded by installer
redis/

# Debug logs
*_debug.log
*.log

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Service runtime artifacts (venvs, models, caches - not source code)
services/**/env/
services/**/.venv/
services/**/venv/
services/**/__pycache__/
services/**/*.egg-info/
services/**/.cache/
services/**/outputs/
services/**/checkpoints/
services/**/models/
services/**/*.safetensors
services/**/*.bin
services/**/*.pt
services/**/*.ckpt

# Reference folder (local-only context, not shipped)
reference/
